  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(cat | jq -r \".tool_input.command // empty\" 2>/dev/null); if echo \"$CMD\" | grep -qE \"rm\\s+-rf\\s+(/|~|\\$HOME)|git\\s+push.*--force|git\\s+reset\\s+--hard|git\\s+clean\\s+-fd\"; then echo \"BLOCKED: Destructive command\" >&2; exit 2; fi'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(cat | jq -r \".tool_input.command // empty\" 2>/dev/null); if echo \"$CMD\" | grep -qiE \"(api[_-]?key|secret|password|token|credential).*=|export\\s+(AWS|GITHUB|OPENAI|ANTHROPIC)_\"; then echo \"BLOCKED: Potential credential exposure\" >&2; exit 2; fi'"
          }
        ]
      }
    ]
  },
  "Notification": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "afplay /System/Library/Sounds/Glass.aiff"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "afplay /System/Library/Sounds/Funk.aiff"
        }
      ]
    }
  ]
}
